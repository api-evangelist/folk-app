          "http": { "method": "POST", "url": "https://api.folk.app/v1/reminders", "body": { "type": "json", "data": "{\n  \"title\": \"Check in with Jane\",\n  \"dueAt\": \"2026-08-01T09:00:00Z\",\n  \"entityType\": \"person\",\n  \"entityId\": \"\"\n}" } },
          "docs": "Creates a reminder."
